<%- include('../partials/navbar') %>

<div class="form-wrapper">
    <form action="/auth/login" method="POST" class="glass-panel">
        <h1>Welcome Back</h1>
        <p style="text-align: center; color: var(--text-muted); margin-bottom: 2rem;">Log in to your DevConnect account</p>
        
        <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" placeholder="name@company.com" required />
        </div>
        
        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="••••••••" required />
        </div>
        
        <button type="submit" class="btn-action" style="width: 100%; margin-top: 1rem;">Sign In</button>
        
        <p style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: var(--text-muted);">
            Don't have an account? <a href="/auth/register" style="color: var(--primary); font-weight: 600;">Register here</a>
        </p>
    </form>
</div>

<%- include('../partials/footer') %>