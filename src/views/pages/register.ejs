<%- include('../partials/navbar') %>

<div class="form-wrapper">
    <form action="/auth/register" method="POST" class="glass-panel">
        <h1>Create Account</h1>
        <p style="text-align: center; color: var(--text-muted); margin-bottom: 2rem;">Join the DevConnect community today</p>
        
        <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" placeholder="John Doe" required />
        </div>

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" placeholder="name@company.com" required />
        </div>
        
        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="••••••••" required />
        </div>
        
        <button type="submit" class="btn-action" style="width: 100%; margin-top: 1rem;">Get Started</button>
        
        <p style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: var(--text-muted);">
            Already have an account? <a href="/auth/login" style="color: var(--primary); font-weight: 600;">Sign in</a>
        </p>
    </form>
</div>

<%- include('../partials/footer') %>