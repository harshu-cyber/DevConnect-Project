<%- include('../partials/navbar') %>

<div class="form-wrapper">
    <form action="/posts" method="POST" class="glass-panel" style="max-width: 600px;">
        <h1>Share Something</h1>
        <p style="text-align: center; color: var(--text-muted); margin-bottom: 2rem;">What's on your mind today?</p>
        
        <div class="form-group">
            <label>Post Title</label>
            <input type="text" name="title" placeholder="A catchy title..." required />
        </div>

        <div class="form-group">
            <label>Content</label>
            <textarea name="content" placeholder="Share your thoughts, code snippets, or ideas..." required rows="8"></textarea>
        </div>
        
        <button type="submit" class="btn-action" style="width: 100%; margin-top: 1rem;">Publish Post</button>
        
        <p style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: var(--text-muted);">
            <a href="/dashboard" style="color: var(--text-muted);">Cancel and go back</a>
        </p>
    </form>
</div>

<%- include('../partials/footer') %>