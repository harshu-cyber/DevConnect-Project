<%- include('../partials/navbar') %>

<div style="padding: 6rem 0;">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 5rem;">
            <div>
                <h1 style="font-size: 3.5rem; margin-bottom: 0.5rem; text-align: left;">Community Feed</h1>
                <p style="color: var(--text-gray); font-size: 1.1rem;">Explore the latest stories from top engineers.</p>
            </div>
            <a href="/posts/create" class="btn-elite btn-blue">New Post</a>
        </div>

        <div class="elite-grid">
        <% if (posts && posts.length > 0) { %>
            <% posts.forEach(post => { %>
                <div class="elite-card post-elite">
                    <h3><%= post.title %></h3>
                    <p><%= post.content.substring(0, 100) %><%= post.content.length > 100 ? '...' : '' %></p>
                    
                    <div class="post-footer">
                        <span>by <strong style="color: var(--text-black);">@<%= post.author ? post.author.name : 'Unknown' %></strong></span>
                        <a href="/posts/<%= post._id %>" style="color: var(--accent-blue); text-decoration: none; font-weight: 600;">Read</a>
                    </div>

                    <% if (locals.user && post.author && post.author._id.toString() === locals.user.userId) { %>
                        <div style="margin-top: 2rem; display: flex; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.05);">
                            <a href="/posts/<%= post._id %>/edit" style="color: var(--text-gray); text-decoration: none; font-size: 0.85rem;">Edit</a>
                            <form action="/posts/<%= post._id %>/delete" method="POST" style="display:inline; padding:0; background:transparent; border:none; box-shadow:none; width:auto;">
                                <button type="submit" style="color: #ff3b30; background: none; border: none; cursor: pointer; font-size: 0.85rem;" onclick="return confirm('Delete this post?')">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <div class="elite-card" style="grid-column: 1 / -1; text-align: center; padding: 8rem;">
                <p style="color: var(--text-gray); font-size: 1.2rem;">The community is quiet. Be the first to post!</p>
            </div>
        <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>