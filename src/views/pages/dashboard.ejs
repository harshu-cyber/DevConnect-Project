<%- include('../partials/navbar') %>

<div style="padding: 4rem 0;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
        <h1 style="margin: 0; text-align: left;">Community Feed</h1>
        <a href="/posts/create" class="btn-action">Create New Post</a>
    </div>

    <div class="posts-list">
    <% if (posts && posts.length > 0) { %>
        <% posts.forEach(post => { %>
            <div class="post-card glass-panel">
                <h3><%= post.title %></h3>
                <p><%= post.content.substring(0, 150) %><%= post.content.length > 150 ? '...' : '' %></p>
                <p class="post-author">@<%= post.author ? post.author.name : 'Unknown' %></p>
                
                <div class="card-actions" style="margin-top: 1.5rem; display: flex; gap: 0.5rem;">
                    <a href="/posts/<%= post._id %>" class="btn-action" style="padding: 0.5rem 1.2rem; font-size: 0.85rem;">Read More</a>
                    
                    <% if (locals.user && post.author && post.author._id.toString() === locals.user.userId) { %>
                        <a href="/posts/<%= post._id %>/edit" class="btn-action" style="padding: 0.5rem 1.2rem; font-size: 0.85rem; background: var(--glass-highlight);">Edit</a>
                        <form action="/posts/<%= post._id %>/delete" method="POST" style="display:inline; padding:0; background:transparent; border:none; box-shadow:none; width:auto;">
                            <button type="submit" class="btn-action" style="padding: 0.5rem 1.2rem; font-size: 0.85rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="glass-panel" style="padding: 4rem; text-align: center; grid-column: 1 / -1;">
            <p style="color: var(--text-muted); font-size: 1.2rem;">No posts yet. Be the first to share something!</p>
        </div>
    <% } %>
    </div>
</div>

<%- include('../partials/footer') %>