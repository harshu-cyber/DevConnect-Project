<%- include('../partials/navbar') %>

<div class="hero-elite">
    <div class="container">
        <h1>Connect. Create. <br> Grow together.</h1>
        <p>The premier platform for software engineers to share insights and build the future of the web.</p>
        
        <div style="display: flex; gap: 1.5rem; justify-content: center;">
            <% if (locals.user) { %>
                <a href="/dashboard" class="btn-elite btn-blue">Go to Dashboard</a>
            <% } else { %>
                <a href="/auth/register" class="btn-elite btn-blue">Start Your Journey</a>
                <a href="/auth/login" class="btn-elite" style="background: transparent; color: var(--text-black); border: 1px solid var(--border-light);">Sign In</a>
            <% } %>
        </div>
    </div>
</div>

<div class="container" style="padding-bottom: 10rem;">
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
        <div class="elite-card">
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">Minimalist</h3>
            <p style="color: var(--text-gray); font-size: 1rem;">Clean interface designed for maximum focus and productivity.</p>
        </div>
        <div class="elite-card">
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">Scalable</h3>
            <p style="color: var(--text-gray); font-size: 1rem;">Built on modern foundations to handle the next generation of devs.</p>
        </div>
        <div class="elite-card">
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">Collaborative</h3>
            <p style="color: var(--text-gray); font-size: 1rem;">Seamless discussion threads and knowledge sharing tools.</p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
